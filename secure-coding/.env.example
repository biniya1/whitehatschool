# Copy this file to .env and fill in real values. .env is gitignored and
# must never be committed.

# Flask session signing key. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# First admin account, bootstrapped automatically on first run if no admin
# exists yet. Never hardcode admin credentials in source.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# Set to true only when serving over HTTPS (e.g. behind ngrok or a TLS
# reverse proxy) -- otherwise the session cookie's Secure flag will block
# login over plain http.
SESSION_COOKIE_SECURE=false

# Enable Flask debug mode only for local development, never in production.
FLASK_DEBUG=false
